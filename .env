SPRING_APPLICATION_NAME=spring-web

DB_HOST=localhost
DB_PORT=3306
DB_NAME=edulearn
DB_USE_SSL=false
DB_REQUIRE_SSL=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true
DB_TIMEZONE=UTC
DB_USERNAME=root
DB_PASSWORD=123456
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000

JPA_DDL_AUTO=validate
JPA_OPEN_IN_VIEW=false
HIBERNATE_FORMAT_SQL=true
JACKSON_TIME_ZONE=UTC

CACHE_TYPE=redis
REDIS_CACHE_TTL=5m
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2000ms

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

SERVER_PORT=8080

JWT_SECRET=edulearn-super-secret-key-need-at-least-32-bytes-long
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14
JWT_ISSUER=edulearn

ANTHROPIC_ENABLED=false
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=512
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_CONNECT_TIMEOUT_MS=3000
ANTHROPIC_READ_TIMEOUT_MS=30000

CHAT_RATE_LIMIT_MAX_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

APP_EMAIL_ENABLED=false
APP_EMAIL_FROM=noreply@edulearn.com

EXECUTION_LOG_ENABLED=true
EXECUTION_LOG_WARN_THRESHOLD_MS=500
